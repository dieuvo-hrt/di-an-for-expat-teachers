<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Life in Dĩ An — VUS Careers</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@500;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #F3F6EF;
    --bg-alt: #E9EFE3;
    --card: #FFFFFF;
    --ink: #16241D;
    --ink-soft: #50615A;
    --line: #D6DECC;
    --pine: #1F4035;
    --pine-deep: #122722;
    --gold: #D69A3B;
    --coral: #D9714A;
    --jade: #4F8C6B;
    --radius: 18px;
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--ink);
    font-family:'Inter', sans-serif;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.display{
    font-family:'Be Vietnam Pro', sans-serif;
    font-weight:800;
    letter-spacing:-0.01em;
    color:var(--pine-deep);
  }
  .mono{
    font-family:'IBM Plex Mono', monospace;
    letter-spacing:0.02em;
  }
  a{color:inherit;}
  .wrap{max-width:1100px; margin:0 auto; padding:0 28px;}
  section{padding:96px 0;}
  section.tight{padding:64px 0;}

  /* ---------- NAV ---------- */
  .nav{
    position:sticky; top:0; z-index:50;
    background:rgba(243,246,239,0.92);
    backdrop-filter:blur(8px);
    border-bottom:1px solid var(--line);
  }
  .nav-inner{
    max-width:1100px; margin:0 auto; padding:16px 28px;
    display:flex; align-items:center; justify-content:space-between; gap:24px;
  }
  .brand{display:flex; align-items:center; gap:10px; font-family:'Be Vietnam Pro'; font-weight:800; font-size:15px; color:var(--pine-deep);}
  .brand .dot{width:9px; height:9px; border-radius:50%; background:var(--gold); display:inline-block;}
  .navlinks{display:flex; gap:6px; flex-wrap:wrap;}
  .navlinks a{
    font-size:13px; font-weight:500; padding:7px 13px; border-radius:999px;
    color:var(--ink-soft); text-decoration:none; white-space:nowrap;
  }
  .navlinks a:hover{background:var(--bg-alt); color:var(--pine-deep);}

  /* ---------- HERO ---------- */
  .hero{padding:72px 0 0 0;}
  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-family:'IBM Plex Mono'; font-size:12px; letter-spacing:0.08em; text-transform:uppercase;
    color:var(--jade); margin-bottom:22px;
  }
  .eyebrow::before{content:""; width:18px; height:1px; background:var(--jade);}
  .hero h1{font-size:clamp(36px, 5.2vw, 62px); line-height:1.05; max-width:820px;}
  .hero .lede{font-size:18px; color:var(--ink-soft); max-width:560px; margin-top:22px;}
  .hero-cta{margin-top:34px; display:flex; gap:14px; flex-wrap:wrap; align-items:center;}
  .btn{
    display:inline-block; background:var(--pine); color:#fff; text-decoration:none;
    padding:14px 26px; border-radius:999px; font-weight:600; font-size:14px;
    transition:transform .15s ease, background .15s ease;
  }
  .btn:hover{background:var(--pine-deep); transform:translateY(-1px);}
  .btn.ghost{background:transparent; color:var(--pine-deep); border:1.5px solid var(--line);}
  .btn.ghost:hover{border-color:var(--pine);}

  .stat-strip{
    margin-top:56px; display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    background:var(--line); border:1px solid var(--line); border-radius:var(--radius); overflow:hidden;
  }
  .stat-strip div{background:var(--card); padding:24px 22px;}
  .stat-strip .num{font-family:'IBM Plex Mono'; font-weight:600; font-size:26px; color:var(--pine-deep);}
  .stat-strip .lbl{font-size:13px; color:var(--ink-soft); margin-top:4px;}

  /* ---------- ROUTE / COMMUTE VISUALIZER (signature element) ---------- */
  .route{margin-top:64px; padding:36px 0 8px;}
  .route-label{font-family:'IBM Plex Mono'; font-size:12px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:.06em; margin-bottom:28px;}
  .route-line{
    position:relative; display:flex; justify-content:space-between; align-items:flex-start;
    padding-top:14px;
  }
  .route-line::before{
    content:""; position:absolute; top:5px; left:0; right:0; height:0;
    border-top:2px dashed var(--line);
  }
  .route-stop{position:relative; text-align:left; flex:1; padding-right:18px;}
  .route-stop .pin{width:10px; height:10px; border-radius:50%; background:var(--gold); margin-bottom:14px; position:relative; z-index:2;}
  .route-stop:first-child .pin, .route-stop:last-child .pin{background:var(--pine);}
  .route-stop .mode{font-family:'IBM Plex Mono'; font-size:12px; color:var(--pine-deep); font-weight:600; text-transform:uppercase; letter-spacing:.04em;}
  .route-stop .time{font-size:13px; color:var(--ink-soft); margin-top:3px;}
  .route-stop .city{font-family:'Be Vietnam Pro'; font-weight:700; font-size:15px;}

  /* ---------- SECTION HEADERS ---------- */
  .section-head{max-width:620px; margin-bottom:48px;}
  .section-head .eyebrow{margin-bottom:14px;}
  .section-head h2{font-size:clamp(26px,3.4vw,38px);}
  .section-head p{color:var(--ink-soft); margin-top:14px; font-size:16px;}

  .alt{background:var(--bg-alt);}

  /* ---------- TWO-COL NEIGHBORHOOD ---------- */
  .twocol{display:grid; grid-template-columns:1fr 1fr; gap:24px;}
  .feel-card{
    background:var(--card); border-radius:var(--radius); padding:30px 28px; border:1px solid var(--line);
  }
  .feel-card .tag{font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:var(--coral); margin-bottom:10px; display:block;}
  .feel-card h3{font-size:20px; margin-bottom:10px;}
  .feel-card p{color:var(--ink-soft); font-size:14.5px;}

  .pace-bar{margin-top:24px; background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:24px 28px; display:flex; gap:28px; flex-wrap:wrap;}
  .pace-bar div{flex:1; min-width:180px;}
  .pace-bar h4{font-size:13px; font-family:'IBM Plex Mono'; color:var(--pine); margin-bottom:6px; text-transform:uppercase; letter-spacing:.04em;}
  .pace-bar p{font-size:14px; color:var(--ink-soft);}

  /* ---------- TESTIMONIAL PLACEHOLDER ---------- */
  .testi-note{
    background:#FBF1DE; border:1px dashed #D8B36C; color:#7A5A1E; font-size:13px;
    padding:12px 18px; border-radius:12px; margin-bottom:28px; font-family:'IBM Plex Mono';
  }
  .testi-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:20px;}
  .testi-card{
    background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:26px;
    display:flex; flex-direction:column; gap:16px;
  }
  .avatar{width:46px; height:46px; border-radius:50%; background:linear-gradient(135deg, var(--jade), var(--pine)); display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-family:'Be Vietnam Pro';}
  .testi-card p{font-size:14px; color:var(--ink-soft); font-style:italic;}
  .testi-card .who{font-size:13px; font-weight:600; color:var(--pine-deep); font-style:normal;}
  .testi-card .from{font-size:12px; color:var(--ink-soft); font-style:normal;}

  /* ---------- DAY SPLIT ---------- */
  .day-split{display:grid; grid-template-columns:1fr 1fr; gap:32px;}
  .day-block h3{font-size:15px; font-family:'IBM Plex Mono'; text-transform:uppercase; letter-spacing:.04em; color:var(--pine); margin-bottom:6px;}
  .day-block .big{font-size:22px; font-family:'Be Vietnam Pro'; font-weight:700; margin-bottom:14px;}
  .day-block p.sub{color:var(--ink-soft); font-size:14.5px; margin-bottom:22px;}

  .info-grid{display:grid; grid-template-columns:1fr 1fr; gap:14px;}
  .info-card{background:var(--card); border:1px solid var(--line); border-radius:14px; padding:18px 20px;}
  .info-card .h{font-size:13px; font-weight:700; color:var(--pine-deep); margin-bottom:8px;}
  .info-card ul{list-style:none; font-size:13.5px; color:var(--ink-soft);}
  .info-card li{margin-bottom:5px; padding-left:14px; position:relative;}
  .info-card li::before{content:"–"; position:absolute; left:0; color:var(--coral);}

  /* ---------- COST COMPARISON ---------- */
  .cost-card{background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:34px;}
  .cost-row{margin-bottom:26px;}
  .cost-row:last-child{margin-bottom:0;}
  .cost-row .top{display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px;}
  .cost-row .label{font-size:14px; font-weight:600;}
  .cost-row .delta{font-family:'IBM Plex Mono'; font-size:13px; color:var(--coral); font-weight:600;}
  .bartrack{height:10px; background:var(--bg-alt); border-radius:999px; overflow:hidden; position:relative; margin-bottom:4px;}
  .bartrack .hcmc{position:absolute; inset:0; background:#C9D2C1; border-radius:999px;}
  .bartrack .dian{position:absolute; top:0; bottom:0; left:0; background:var(--pine); border-radius:999px;}
  .bar-legend{display:flex; gap:18px; font-size:12px; color:var(--ink-soft); margin-bottom:22px; font-family:'IBM Plex Mono';}
  .bar-legend span{display:flex; align-items:center; gap:6px;}
  .bar-legend i{width:10px; height:10px; border-radius:3px; display:inline-block;}

  .accom-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-top:36px;}
  .accom-card{background:var(--card); border:1px solid var(--line); border-radius:16px; padding:22px;}
  .accom-card .icon{width:34px; height:34px; border-radius:9px; background:var(--bg-alt); margin-bottom:14px; display:flex; align-items:center; justify-content:center; color:var(--pine); font-weight:700; font-family:'IBM Plex Mono'; font-size:13px;}
  .accom-card h4{font-size:14.5px; margin-bottom:8px;}
  .accom-card p{font-size:13px; color:var(--ink-soft);}

  /* ---------- COMMUNITY ---------- */
  .community-grid{display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-bottom:32px;}
  .community-card{border-radius:var(--radius); padding:30px; border:1px solid var(--line);}
  .community-card.local{background:var(--card);}
  .community-card.expat{background:var(--pine-deep); color:#EFF4EC;}
  .community-card .tag{font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.06em; margin-bottom:12px; display:block; opacity:.75;}
  .community-card h3{font-size:18px; margin-bottom:12px;}
  .community-card.expat h3{color:#fff;}
  .community-card p{font-size:14px; color:var(--ink-soft); margin-bottom:6px;}
  .community-card.expat p{color:#C9D6C7;}

  .support-strip{display:flex; gap:16px; flex-wrap:wrap;}
  .support-pill{
    background:var(--card); border:1px solid var(--line); border-radius:999px;
    padding:10px 18px; font-size:13px; font-weight:600; display:flex; align-items:center; gap:8px;
  }
  .support-pill::before{content:"✓"; color:var(--jade); font-weight:700;}

  .fit-box{
    margin-top:40px; background:linear-gradient(135deg, #1F4035, #122722); color:#fff;
    border-radius:var(--radius); padding:36px 38px;
  }
  .fit-box .tag{font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:#9FCB9E; margin-bottom:14px; display:block;}
  .fit-box h3{color:#fff; font-size:21px; margin-bottom:16px;}
  .fit-list{list-style:none; display:grid; grid-template-columns:1fr 1fr; gap:10px 24px;}
  .fit-list li{font-size:14px; color:#DCE7DA; padding-left:20px; position:relative;}
  .fit-list li::before{content:"—"; position:absolute; left:0; color:#9FCB9E;}

  /* ---------- BENEFITS TABLE ---------- */
  .benefit-grid{display:grid; grid-template-columns:1fr 1fr; gap:24px;}
  .benefit-card{background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:30px;}
  .benefit-card .kicker{font-family:'IBM Plex Mono'; font-size:12px; text-transform:uppercase; letter-spacing:.05em; color:var(--ink-soft); margin-bottom:6px;}
  .benefit-card h3{font-size:20px; margin-bottom:18px;}
  .benefit-card ul{list-style:none;}
  .benefit-card li{
    font-size:14.5px; padding:11px 0; border-top:1px solid var(--line); display:flex; align-items:center; gap:10px;
  }
  .benefit-card li:first-child{border-top:none;}
  .benefit-card li::before{content:""; width:6px; height:6px; border-radius:50%; background:var(--gold); flex-shrink:0;}
  .benefit-card.ft li::before{background:var(--pine);}
  .gross{
    margin-top:18px; background:var(--bg-alt); border-radius:12px; padding:14px 18px;
    font-family:'IBM Plex Mono'; font-size:13px; color:var(--pine-deep);
  }

  /* ---------- FINAL CTA ---------- */
  .final-cta{
    text-align:center; background:var(--pine); color:#fff; border-radius:28px; padding:64px 40px; margin:0 0 40px;
  }
  .final-cta h2{color:#fff; font-size:clamp(26px,3.6vw,38px); max-width:600px; margin:0 auto 18px;}
  .final-cta p{color:#CFE0CC; max-width:480px; margin:0 auto 30px; font-size:15px;}
  .final-cta .btn{background:#fff; color:var(--pine-deep);}
  .final-cta .btn:hover{background:#EFEAD9;}

  footer{padding:30px 0; text-align:center; font-size:12px; color:var(--ink-soft); font-family:'IBM Plex Mono';}

  @media (max-width:760px){
    .twocol, .day-split, .info-grid, .testi-grid, .accom-grid, .community-grid, .fit-list, .benefit-grid{
      grid-template-columns:1fr;
    }
    .stat-strip{grid-template-columns:1fr;}
    .route-line{flex-direction:column; gap:22px;}
    .route-line::before{display:none;}
    .navlinks{display:none;}
    section{padding:64px 0;}
  }
</style>
</head>
<body>

