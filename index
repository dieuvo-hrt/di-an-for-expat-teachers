  <div class="nav-inner">
    <div class="brand"><span class="dot"></span> VUS Careers</div>
    <div class="navlinks">
      <a href="#overview">Overview</a>
      <a href="#daily">Daily Life</a>
      <a href="#cost">Cost &amp; Housing</a>
      <a href="#community">Community</a>
